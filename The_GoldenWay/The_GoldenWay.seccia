"dialogs": [
{
"sid": 32,
"uid": "D_RHALE_BAULE",
"content": {
"sentence": {
"sentences": [
{
"id": 2,
"speaker": "O_RHALE_BAULE",
"text": {
"fr": "Ah, inspecteur ! Vous tombez bien !",
"en": "Ah, inspector ! You come at a good time !"
},
"sentences": [
{
"id": 3,
"choice": true,
"text": {
"fr": "Qu'est ce qu'il y a ?",
"en": "What is it ?"
},
"sentences": [
{
"id": 4,
"sentences": [
{
"id": 5,
"text": {
"fr": "Vous pouvez allez me chercher de l'eau ?",
"en": "Could you perhaps go and fetch me some water ?"
},
"speaker": "O_RHALE_BAULE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"exit": true
}
],
"text": {
"fr": "Il fait trčs chaud içi, et je commence ŕ avoir soif.",
"en": "It's very hot in here, and I'm starting to get thirsty."
},
"speaker": "O_RHALE_BAULE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
}
],
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"never_hide": true
}
],
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
},
{
"id": 9,
"sentences": [
{
"id": 10,
"choice": true,
"sentences": [
{
"id": 13,
"text": {
"fr": "Merçi. Tenez, voici la clé du wagon restaurant. Vous en aurez besoin pour votre enquęte.",
"en": "Thank you. Here, take this. It's key for the dining car. You might need it for your case."
},
"speaker": "O_RHALE_BAULE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"exit": true
}
],
"text": {
"fr": "Oui, voilŕ.",
"en": "Yes, here."
},
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"never_hide": true
},
{
"id": 11,
"choice": true,
"sentences": [
{
"id": 12,
"text": {
"fr": "Et bien, qu'attendez vous ?",
"en": "Well, what are you waiting for ?"
},
"speaker": "O_RHALE_BAULE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"exit": true
}
],
"text": {
"fr": "Non, pas encore.",
"en": "No, not yet."
},
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"never_hide": true
}
],
"text": {
"fr": "Ah, inspecteur ! Vous avez de l'eau ?",
"en": "Ah, inspector ! Do you have water ?"
},
"speaker": "O_RHALE_BAULE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
}
],
"voice": {

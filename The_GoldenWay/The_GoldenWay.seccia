{},
{}
]
}
},
"nextID": 14
}
},
{
"sid": 45,
"uid": "D_DIO_SCESE",
"content": {
"sentence": {
"sentences": [
{
"id": 1,
"text": {
"fr": "Ah Inspecteur ! Vous me devez une explication !"
},
"speaker": "O_DIO_SCESE",
"sentences": [
{
"id": 2,
"choice": true,
"text": {
"fr": "Comment ça ?"
},
"sentences": [
{
"id": 3,
"sentences": [
{
"id": 5,
"choice": true,
"sentences": [
{
"id": 9,
"sentences": [
{
"id": 10,
"choice": true,
"sentences": [
{
"id": 12,
"sentences": [
{
"id": 13,
"sentences": [
{
"id": 14,
"sentences": [
{
"id": 16,
"text": {
"fr": "J'ai des information qui pourrait vous interessez pour votre enquęte..."
},
"speaker": "O_DIO_SCESE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"exit": true
}
],
"text": {
"fr": "Vous savez quoi ? Si m'apporter une preuve qu'il est une âme damné, venez me voir."
},
"speaker": "O_DIO_SCESE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
}
],
"text": {
"fr": "Mais j'en suis persuadé !"
},
"speaker": "O_DIO_SCESE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
}
],
"text": {
"fr": "Et bien... Non."
},
"speaker": "O_DIO_SCESE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
}
],
"text": {
"fr": "Et, vous avez une preuve de ce que vous dites ?"
},
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"never_hide": true
},
{
"id": 11,
"choice": true,
"text": {
"fr": "Oui, vous avez sans doute raison [CHOIX DE COUPABLE]"
},
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"never_hide": true,
"exit": true
}
],
"text": {
"fr": "Je parle de Kisel Patron, évidemment. Si vous chercher un coupable, le voilŕ !"
},
"speaker": "O_DIO_SCESE",
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
}
}
],
"text": {
"fr": "De quoi est ce que vous parlez ?"
},
"voice": {
"en": [
{},
{},
{},
{}
],
"fr": [
{},
{},
{},
{}
]
},
"never_hide": true
}
],
"text": {
"fr": "Vous passez ŕ côté d'un sataniste, un défiant de Dieu, et vous ne l'arręter męme pas."
},
"speaker": "O_DIO_SCESE",
